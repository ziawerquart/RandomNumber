<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="随机数生成"
            android:textStyle="bold"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/editMin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="最小值"
            android:inputType="numberSigned" />

        <EditText
            android:id="@+id/editMax"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="最大值"
            android:inputType="numberSigned" />

        <EditText
            android:id="@+id/editCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="生成个数"
            android:inputType="number" />

        <Button
            android:id="@+id/btnGenerate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="生成随机数" />

        <TextView
            android:id="@+id/textGenerateResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="结果将显示在这里" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="批量抽取"
            android:textStyle="bold"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/editPickItems"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:gravity="top|start"
            android:hint="输入项目（每行一个，至少两个）"
            android:inputType="textMultiLine"
            android:minLines="4" />

        <EditText
            android:id="@+id/editPickCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="抽取数量"
            android:inputType="number" />

        <Button
            android:id="@+id/btnPick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="开始抽取" />

        <TextView
            android:id="@+id/textPickResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="结果将显示在这里" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#DDDDDD" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="一键打乱"
            android:textStyle="bold"
            android:textSize="20sp" />

        <EditText
            android:id="@+id/editShuffleItems"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:gravity="top|start"
            android:hint="输入项目（每行一个，至少两个）"
            android:inputType="textMultiLine"
            android:minLines="4" />

        <Button
            android:id="@+id/btnShuffle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="打乱顺序" />

        <TextView
            android:id="@+id/textShuffleResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:text="结果将显示在这里" />

    </LinearLayout>
</ScrollView>
